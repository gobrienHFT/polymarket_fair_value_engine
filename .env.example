# This file is safe to commit. Keep real secrets in your local .env only.
# .env is gitignored by default in this repo.

LOG_LEVEL=INFO
PMFE_OUTPUT_ROOT=runs

# Public endpoints
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_CHAIN_ID=137
POLYGON_RPC=

# Live trading credentials (leave blank unless you explicitly use --live)
POLY_PRIVATE_KEY=
POLY_FUNDER=
POLY_SIGNATURE_TYPE=0
CLOB_API_KEY=
CLOB_SECRET=
CLOB_PASSPHRASE=

# Market family defaults
PMFE_DEFAULT_SERIES=btc-updown-5m
BOT_TARGET_SERIES_PREFIX=btc-updown-5m
BOT_TARGET_PROBE_INTERVALS=6
PMFE_MAX_MINUTES_TO_EXPIRY=10
PMFE_NO_TRADE_WINDOW_SECONDS=45

# External reference pricing
PMFE_PRICE_SOURCE=coinbase
PMFE_VOL_LOOKBACK_MINUTES=90
BOT_BASE_ANNUAL_VOL=0.80
PMFE_VOL_FLOOR=0.20
PMFE_UNCERTAINTY_MULTIPLIER=0.50
PMFE_MARKET_BLEND_WEIGHT=0.20

# Strategy defaults
BOT_POLL_SECONDS=1
PMFE_QUOTE_HALF_SPREAD=0.02
PMFE_MIN_EDGE=0.015
PMFE_INVENTORY_SKEW_PER_CONTRACT=0.003
PMFE_QUOTE_NOTIONAL=20
BOT_MIN_ORDER_USDC=5
PMFE_TOUCH_FILL_ONLY=1
# PMFE_TOUCH_FILL_ONLY=1 means paper fills on touch-or-cross.
# Set PMFE_TOUCH_FILL_ONLY=0 to allow replay fills within PMFE_REPLAY_FILL_SLACK.
PMFE_REPLAY_FILL_SLACK=0.01
BOT_PRICE_TICK=0.01
BOT_SIZE_TICK=0.1
PMFE_REPRICE_THRESHOLD=0.01
PMFE_REPRICE_COOLDOWN_SECONDS=5

# Risk defaults
BOT_BANKROLL_USDC=1000
BOT_MAX_FRACTION_PER_TRADE=0.05
PMFE_MAX_NOTIONAL_PER_MARKET=75
PMFE_MAX_GROSS_EXPOSURE=250
PMFE_MAX_NET_EXPOSURE_PER_SERIES=125
PMFE_MAX_ORDER_SIZE=100
PMFE_MAX_OPEN_ORDERS=8
PMFE_STALE_DATA_SECONDS=20
PMFE_LIVE_ENABLED=0
PMFE_KILL_SWITCH_FILE=
